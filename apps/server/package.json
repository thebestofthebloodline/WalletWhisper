    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push"
  },
  "dependencies": {
    "@walletwhisper/shared": "workspace:*",
    "@prisma/client": "^5.14.0",
    "fastify": "^4.27.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/jwt": "^8.0.0",
    "socket.io": "^4.7.5",
    "zod": "^3.23.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "bs58": "^6.0.0",
    "nanoid": "^5.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "prisma": "^5.14.0",
    "tsx": "^4.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.12.0"
  }
