{
  "manifest_version": 3,
  "name": "WalletWhisper",
  "version": "0.1.0",
  "description": "Wallet-to-wallet encrypted chat for trading terminals. Not affiliated with Terminal Trade, Padre, or Axiom.",
  "permissions": [
    "storage",
    "notifications",
    "activeTab",
    "alarms"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/index.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "WalletWhisper"
  },
  "web_accessible_resources": [
    {
      "resources": ["page-bridge.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
